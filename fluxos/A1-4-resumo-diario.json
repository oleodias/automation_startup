      "id": "a14-read",
      "name": "Ler aba Agenda",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [220, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "h1",
              "leftValue": "={{ $json.data }}",
              "rightValue": "={{ $now.setZone('America/Sao_Paulo').toFormat('dd/MM/yyyy') }}",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a14-filter",
      "name": "Consultas de hoje",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "const itens = $input.all().map(i => i.json);\nconst total = itens.length;\nconst confirmadas = itens.filter(i => i.status === 'confirmada');\nconst aguardando = itens.filter(i => i.status === 'aguardando resposta');\nconst mudancas = itens.filter(i => i.status === 'cancelada' || i.status === 'remarcada');\n\nlet msg = `☀️ Bom dia! Resumo da Clínica Sorriso para hoje:\\n\\n`;\nmsg += `📅 Consultas no dia: ${total}\\n`;\nmsg += `✅ Confirmadas: ${confirmadas.length}\\n`;\nmsg += `⏳ Sem resposta: ${aguardando.length}\\n`;\nmsg += `🔁 Canceladas/remarcadas: ${mudancas.length}\\n`;\n\nif (aguardando.length > 0) {\n  msg += `\\n📞 Ligar para confirmar:\\n`;\n  msg += aguardando.map(i => `• ${i.paciente} — ${i.hora} — ${i.telefone}`).join('\\n');\n}\n\nif (mudancas.length > 0) {\n  msg += `\\n\\n🔁 Horários liberados/alterados:\\n`;\n  msg += mudancas.map(i => `• ${i.paciente} — ${i.hora} (${i.status})`).join('\\n');\n}\n\nreturn [{ json: { para: 'NUMERO_DA_SECRETARIA', mensagem: msg } }];"
      },
      "id": "a14-code",
      "name": "Montar resumo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
