# Copie este arquivo para .env (cp .env.example .env) e preencha.
# O .env NUNCA vai para o git (está no .gitignore) — guarde uma cópia no Bitwarden.

# --- Domínios (criados no DuckDNS no Passo 4 do guia) ---
N8N_DOMAIN=SEUNOME-n8n.duckdns.org
EVO_DOMAIN=SEUNOME-evo.duckdns.org

# --- Domínio oficial da página "Em breve" (o que você registrou no Registro.br) ---
# Ex.: moderneasy.com.br  (NÃO coloque http:// nem www — o Caddy já cuida do www)
SITE_DOMAIN=moderneasy.com.br

# --- Banco de dados ---
POSTGRES_USER=automacao
# Gere com: openssl rand -hex 16
POSTGRES_PASSWORD=

# --- n8n ---
# Gere com: openssl rand -hex 32
# ATENÇÃO: se perder esta chave, perde acesso às credenciais salvas no n8n.
N8N_ENCRYPTION_KEY=

# --- Evolution API ---
# Gere com: openssl rand -hex 16
# É a "senha mestra" da API de WhatsApp — quem tem ela manda mensagens pelo seu número.
EVOLUTION_API_KEY=
